BOT_TOKEN=telegram_bot_tokeningiz
ADMIN_IDS=123456789,987654321

# Nomzodlar va vakansiyalar yuboriladigan kanal.
# Bot kanalga admin qilingan bo'lishi kerak.
# Masalan: @ish_elonlari yoki -1001234567890
PUBLIC_CHANNEL_ID=

# SQLite fayl joylashuvi. Yangilashda shu fayl o'chirilmasa, ma'lumotlar saqlanadi.
DATABASE_PATH=data/bot.sqlite3

# Bot ishga tushganda va admin so'raganda SQLite backup shu papkaga olinadi.
BACKUP_DIR=backups
